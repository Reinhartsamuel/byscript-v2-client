{
  "rewrites": [
    {
      "source": "/web/:path*",
      "destination": "https://byscript-web.vercel.app/web/:path*"
    },
    {
      "source": "/admin/:path*",
      "destination": "https://byscript-web.vercel.app/admin/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}